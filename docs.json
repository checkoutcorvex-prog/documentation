            "pages": [
              "sections/overview",
              "sections/anatomy",
              "sections/schema-reference",
              "sections/data-attributes",
              "sections/blocks",
              "sections/lifecycle",
              "sections/base-section",
              "sections/registry",
              "sections/bundles",
              "sections/built-in-library"
